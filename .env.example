# ===== LLMプロバイダー設定 =====
# true の場合: claude CLI サブプロセスを使用（ローカル実行用）
# false（デフォルト）: Anthropic API を直接呼び出し
USE_CLAUDE_CODE=false

# Anthropic APIキー（USE_CLAUDE_CODE=false の場合に必要）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# 使用するモデル
CLAUDE_MODEL=claude-opus-4-5

# ===== リポジトリパス =====
# 解析対象リポジトリ（カンマ区切りで複数指定可）
# 例: 単一リポ
REPO_PATHS=/path/to/your/project
# 例: 複数リポ（バックエンド＋フロントエンド）
# REPO_PATHS=/path/to/backend,/path/to/frontend

# ===== 出力ディレクトリ =====
OUTPUT_DIR=./output

# ===== E2Eテスト設定 =====
# テスト対象のURL
E2E_BASE_URL=http://localhost:3000

# ヘッドレスモード（true: 画面なし, false: 画面あり）
E2E_HEADLESS=true

# テストユーザー認証情報
E2E_TEST_EMAIL=test@example.com
E2E_TEST_PASSWORD=password

# E2Eタイムアウト（ミリ秒）
E2E_TIMEOUT_MS=30000

# エラー時の最大リトライ回数
E2E_MAX_RETRIES=3

# ===== Claude CLI設定 =====
# claude CLI のマルチターン上限
CLAUDE_MAX_TURNS=100
# claude CLI に許可するツール（カンマ区切り）
CLAUDE_ALLOWED_TOOLS=Read,Glob,Grep,Bash
# analyze_codebase のタイムアウト（秒）
CLAUDE_ANALYZE_TIMEOUT=600

# ===== プロジェクトコンテキスト設定 =====
# コンテキストとして読み込むファイル名（カンマ区切り）
# PROJECT_CONTEXT_FILES=CLAUDE.md,AGENTS.md,README.md
